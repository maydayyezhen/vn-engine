{
  "id": "demo-game",
  "name": "林澄的测试故事",
  "version": "0.1.0",
  "startScriptId": "start",
  "assets": {
    "items": [
      {
        "id": "bg-classroom",
        "name": "教室背景",
        "type": "background",
        "path": "assets/backgrounds/classroom-placeholder.png",
        "description": "开场教室占位背景。"
      },
      {
        "id": "bg-corridor",
        "name": "走廊背景",
        "type": "background",
        "path": "assets/backgrounds/corridor-placeholder.png",
        "description": "离开分支使用的走廊占位背景。"
      },
      {
        "id": "lincheng-normal",
        "name": "林澄普通立绘",
        "type": "character",
        "path": "assets/characters/lincheng/normal-placeholder.png",
        "description": "林澄普通表情。"
      },
      {
        "id": "lincheng-smile",
        "name": "林澄微笑立绘",
        "type": "character",
        "path": "assets/characters/lincheng/smile-placeholder.png",
        "description": "林澄微笑表情。"
      },
      {
        "id": "bgm-main-theme",
        "name": "主旋律 BGM",
        "type": "bgm",
        "path": "assets/bgm/main-theme-placeholder.mp3",
        "description": "测试故事主旋律。"
      },
      {
        "id": "sound-door",
        "name": "开门音效",
        "type": "sound",
        "path": "assets/sound/door-placeholder.mp3",
        "description": "离开教室时的音效。"
      }
    ]
  },
  "characters": [
    {
      "id": "lincheng",
      "name": "林澄",
      "displayName": "林澄",
      "defaultAssetId": "lincheng-normal",
      "color": "#4f8cff",
      "description": "测试故事中的登场角色。",
      "expressions": [
        {
          "id": "normal",
          "name": "普通",
          "assetId": "lincheng-normal"
        },
        {
          "id": "smile",
          "name": "微笑",
          "assetId": "lincheng-smile"
        }
      ]
    }
  ],
  "scripts": [
    {
      "id": "start",
      "name": "开场",
      "nodes": [
        {
          "id": "scene-classroom",
          "type": "scene",
          "backgroundAssetId": "bg-classroom"
        },
        {
          "id": "play-bgm",
          "type": "playAudio",
          "channel": "bgm",
          "assetId": "bgm-main-theme",
          "loop": true
        },
        {
          "id": "show-lincheng",
          "type": "showCharacter",
          "characterId": "lincheng",
          "assetId": "lincheng-normal",
          "expression": "normal",
          "position": "center"
        },
        {
          "id": "narration-intro",
          "type": "narration",
          "text": "这是一个用于验证视觉小说运行时的测试故事。"
        },
        {
          "id": "show-lincheng-smile",
          "type": "showCharacter",
          "characterId": "lincheng",
          "assetId": "lincheng-smile",
          "expression": "smile",
          "position": "center"
        },
        {
          "id": "dialogue-greeting",
          "type": "dialogue",
          "characterId": "lincheng",
          "text": "你终于来了。我有些话想对你说。"
        },
        {
          "id": "choice-stay-or-leave",
          "type": "choice",
          "prompt": "你要怎么做？",
          "options": [
            {
              "id": "stay",
              "text": "留下来听她说",
              "setVariables": {
                "stay": true
              },
              "target": {
                "scriptId": "start",
                "nodeId": "condition-stay"
              }
            },
            {
              "id": "leave",
              "text": "转身离开",
              "setVariables": {
                "stay": false
              },
              "target": {
                "scriptId": "start",
                "nodeId": "condition-stay"
              }
            }
          ]
        },
        {
          "id": "condition-stay",
          "type": "condition",
          "branches": [
            {
              "id": "branch-stay",
              "variable": "stay",
              "operator": "equals",
              "value": true,
              "target": {
                "scriptId": "start",
                "nodeId": "ending-a"
              }
            }
          ],
          "fallbackTarget": {
            "scriptId": "start",
            "nodeId": "scene-corridor"
          }
        },
        {
          "id": "ending-a",
          "type": "narration",
          "text": "你留下来听她说完，窗外的阳光也变得温柔。"
        },
        {
          "id": "hide-lincheng-a",
          "type": "hideCharacter",
          "characterId": "lincheng"
        },
        {
          "id": "stop-bgm-a",
          "type": "stopAudio",
          "channel": "bgm"
        },
        {
          "id": "jump-final-a",
          "type": "jump",
          "target": {
            "scriptId": "start",
            "nodeId": "final-end"
          }
        },
        {
          "id": "scene-corridor",
          "type": "scene",
          "backgroundAssetId": "bg-corridor"
        },
        {
          "id": "play-door-sound",
          "type": "playAudio",
          "channel": "sfx",
          "assetId": "sound-door"
        },
        {
          "id": "ending-b",
          "type": "narration",
          "text": "你安静地离开教室，走廊里只剩下逐渐远去的脚步声。"
        },
        {
          "id": "hide-lincheng-b",
          "type": "hideCharacter",
          "characterId": "lincheng"
        },
        {
          "id": "stop-bgm-b",
          "type": "stopAudio",
          "channel": "bgm"
        },
        {
          "id": "final-end",
          "type": "narration",
          "text": "测试故事到这里结束。"
        }
      ]
    }
  ]
}
