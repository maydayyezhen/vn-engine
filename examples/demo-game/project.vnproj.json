{
  "id": "demo-game",
  "name": "林澄的测试故事",
  "version": "0.1.0",
  "startScriptId": "start",
  "assets": {
    "items": [
      {
        "id": "bg-classroom",
        "name": "教室背景",
        "type": "background",
        "path": "/demo-assets/background/classroom.png",
        "description": "Web demo 阶段的教室背景路径；文件可以后续替换为真实素材。"
      },
      {
        "id": "bg-corridor",
        "name": "走廊背景",
        "type": "background",
        "path": "/demo-assets/background/corridor.png",
        "description": "Web demo 阶段的走廊背景路径；加载失败时 renderer 会使用占位图形。"
      },
      {
        "id": "lincheng-normal",
        "name": "林澄普通立绘",
        "type": "character",
        "path": "/demo-assets/character/lincheng/normal.png",
        "description": "林澄普通表情立绘路径；当前可由占位渲染兜底。"
      },
      {
        "id": "lincheng-smile",
        "name": "林澄微笑立绘",
        "type": "character",
        "path": "/demo-assets/character/lincheng/smile.png",
        "description": "林澄微笑表情立绘路径；当前可由占位渲染兜底。"
      },
      {
        "id": "bgm-main-theme",
        "name": "测试BGM",
        "type": "bgm",
        "path": "/demo-assets/audio/bgm-demo.wav",
        "description": "由 scripts/generate-demo-audio.mjs 生成的可复现 BGM 占位音频。"
      },
      {
        "id": "sound-door",
        "name": "提示音效",
        "type": "sound",
        "path": "/demo-assets/audio/sound-click.wav",
        "description": "由 scripts/generate-demo-audio.mjs 生成的短音效占位音频。"
      },
      {
        "id": "voice-lincheng-001",
        "name": "林澄占位语音",
        "type": "voice",
        "path": "/demo-assets/audio/voice-lincheng-001.wav",
        "description": "由 scripts/generate-demo-audio.mjs 生成的语音占位音频。"
      }
    ]
  },
  "characters": [
    {
      "id": "lincheng",
      "name": "林澄",
      "displayName": "林澄",
      "defaultAssetId": "lincheng-normal",
      "color": "#4f8cff",
      "description": "测试故事中的登场角色。",
      "expressions": [
        {
          "id": "normal",
          "name": "普通",
          "assetId": "lincheng-normal"
        },
        {
          "id": "smile",
          "name": "微笑",
          "assetId": "lincheng-smile"
        }
      ]
    }
  ],
  "scripts": [
    {
      "id": "start",
      "name": "开场",
      "nodes": [
        {
          "id": "scene-classroom",
          "type": "scene",
          "backgroundAssetId": "bg-classroom",
          "transition": "fade",
          "transitionDurationMs": 600
        },
        {
          "id": "play-bgm",
          "type": "playAudio",
          "channel": "bgm",
          "assetId": "bgm-main-theme",
          "loop": true
        },
        {
          "id": "show-lincheng",
          "type": "showCharacter",
          "characterId": "lincheng",
          "assetId": "lincheng-normal",
          "expression": "normal",
          "position": "left",
          "enterEffect": "slideInLeft",
          "transitionDurationMs": 500,
          "scale": 1,
          "opacity": 1,
          "zIndex": 1,
          "flipX": false
        },
        {
          "id": "narration-intro",
          "type": "narration",
          "text": "这是一个用于验证视觉小说运行时的测试故事。",
          "textSpeed": 36,
          "waitForClick": true
        },
        {
          "id": "show-lincheng-smile",
          "type": "showCharacter",
          "characterId": "lincheng",
          "assetId": "lincheng-smile",
          "expression": "smile",
          "position": "center",
          "enterEffect": "fadeIn",
          "transitionDurationMs": 400,
          "scale": 1.05,
          "opacity": 1,
          "zIndex": 2,
          "flipX": false
        },
        {
          "id": "play-voice",
          "type": "playAudio",
          "channel": "voice",
          "assetId": "voice-lincheng-001"
        },
        {
          "id": "dialogue-greeting",
          "type": "dialogue",
          "characterId": "lincheng",
          "text": "你终于来了。我有些话想对你说。",
          "textSpeed": 42,
          "waitForClick": true
        },
        {
          "id": "camera-soft-zoom",
          "type": "camera",
          "zoom": 1.04,
          "offsetX": 0,
          "offsetY": 0,
          "shake": false,
          "shakeIntensity": 0,
          "durationMs": 400
        },
        {
          "id": "stop-voice",
          "type": "stopAudio",
          "channel": "voice"
        },
        {
          "id": "choice-stay-or-leave",
          "type": "choice",
          "prompt": "你要怎么做？",
          "options": [
            {
              "id": "stay",
              "text": "留下来听她说",
              "setVariables": {
                "stayed": true
              },
              "target": {
                "scriptId": "start",
                "label": "after_choice"
              }
            },
            {
              "id": "leave",
              "text": "转身离开",
              "setVariables": {
                "stayed": false
              },
              "target": {
                "scriptId": "start",
                "label": "after_choice"
              }
            }
          ]
        },
        {
          "id": "label-after-choice",
          "type": "label",
          "name": "after_choice",
          "description": "玩家做出是否留下的选择后进入逻辑判断。"
        },
        {
          "id": "condition-stay",
          "type": "condition",
          "condition": {
            "kind": "variable",
            "variableName": "stayed",
            "operator": "eq",
            "value": true
          },
          "trueTarget": {
            "scriptId": "start",
            "label": "stay_route"
          },
          "falseTarget": {
            "scriptId": "start",
            "label": "leave_route"
          }
        },
        {
          "id": "label-stay-route",
          "type": "label",
          "name": "stay_route",
          "description": "留下路线。"
        },
        {
          "id": "set-affection-add",
          "type": "setVariable",
          "variableName": "affection",
          "operator": "add",
          "value": 2
        },
        {
          "id": "set-ending-hint-warm",
          "type": "setVariable",
          "variableName": "endingHint",
          "operator": "set",
          "value": "warm"
        },
        {
          "id": "condition-affection",
          "type": "condition",
          "condition": {
            "kind": "and",
            "conditions": [
              {
                "kind": "variable",
                "variableName": "affection",
                "operator": "gte",
                "value": 2
              },
              {
                "kind": "variable",
                "variableName": "stayed",
                "operator": "eq",
                "value": true
              }
            ]
          },
          "trueTarget": {
            "scriptId": "start",
            "label": "ending_a"
          },
          "falseTarget": {
            "scriptId": "start",
            "label": "leave_route"
          }
        },
        {
          "id": "label-ending-a",
          "type": "label",
          "name": "ending_a",
          "description": "温柔结局标签。"
        },
        {
          "id": "ending-a",
          "type": "narration",
          "text": "你留下来听她说完，窗外的阳光也变得温柔。"
        },
        {
          "id": "hide-lincheng-a",
          "type": "hideCharacter",
          "characterId": "lincheng",
          "exitEffect": "fadeOut",
          "transitionDurationMs": 500
        },
        {
          "id": "stop-bgm-a",
          "type": "stopAudio",
          "channel": "bgm"
        },
        {
          "id": "jump-final-a",
          "type": "jump",
          "target": {
            "scriptId": "start",
            "label": "final_end"
          }
        },
        {
          "id": "label-leave-route",
          "type": "label",
          "name": "leave_route",
          "description": "离开路线。"
        },
        {
          "id": "set-ending-hint-quiet",
          "type": "setVariable",
          "variableName": "endingHint",
          "operator": "set",
          "value": "quiet"
        },
        {
          "id": "scene-corridor",
          "type": "scene",
          "backgroundAssetId": "bg-corridor",
          "transition": "slideLeft",
          "transitionDurationMs": 500
        },
        {
          "id": "play-door-sound",
          "type": "playAudio",
          "channel": "sound",
          "assetId": "sound-door"
        },
        {
          "id": "camera-corridor-shake",
          "type": "camera",
          "zoom": 1,
          "offsetX": 0,
          "offsetY": 0,
          "shake": true,
          "shakeIntensity": 8,
          "durationMs": 300
        },
        {
          "id": "ending-b",
          "type": "narration",
          "text": "你安静地离开教室，走廊里只剩下逐渐远去的脚步声。"
        },
        {
          "id": "hide-lincheng-b",
          "type": "hideCharacter",
          "characterId": "lincheng",
          "exitEffect": "slideOutRight",
          "transitionDurationMs": 500
        },
        {
          "id": "stop-bgm-b",
          "type": "stopAudio",
          "channel": "bgm"
        },
        {
          "id": "label-final-end",
          "type": "label",
          "name": "final_end",
          "description": "公共结束标签。"
        },
        {
          "id": "final-end",
          "type": "narration",
          "text": "测试故事到这里结束。"
        }
      ]
    }
  ],
  "variables": [
    {
      "name": "affection",
      "type": "number",
      "defaultValue": 0,
      "description": "林澄好感度。"
    },
    {
      "name": "stayed",
      "type": "boolean",
      "defaultValue": false,
      "description": "玩家是否选择留下。"
    },
    {
      "name": "endingHint",
      "type": "string",
      "defaultValue": "",
      "description": "结局提示文本。"
    }
  ]
}
