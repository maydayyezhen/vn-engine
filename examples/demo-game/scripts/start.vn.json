{
  "id": "start",
  "name": "开场",
  "nodes": [
    {
      "id": "scene-classroom",
      "type": "scene",
      "backgroundAssetId": "bg-classroom",
      "transition": "fade",
      "transitionDurationMs": 600
    },
    {
      "id": "play-bgm",
      "type": "playAudio",
      "channel": "bgm",
      "assetId": "bgm-main-theme",
      "loop": true
    },
    {
      "id": "show-lincheng",
      "type": "showCharacter",
      "characterId": "lincheng",
      "assetId": "lincheng-normal",
      "expression": "normal",
      "position": "left",
      "enterEffect": "slideInLeft",
      "transitionDurationMs": 500,
      "scale": 1,
      "opacity": 1,
      "zIndex": 1,
      "flipX": false
    },
    {
      "id": "action-sequence-intro",
      "type": "actionSequence",
      "name": "intro-presentation",
      "waitForCompletion": true,
      "autoNext": true,
      "actions": [
        {
          "id": "action-bg-fade",
          "type": "scene",
          "backgroundAssetId": "bg-classroom",
          "transition": "fade",
          "durationMs": 300,
          "easing": "linear"
        },
        {
          "id": "action-show-lincheng",
          "type": "showCharacter",
          "characterId": "lincheng",
          "expression": "normal",
          "position": "left",
          "scale": 1,
          "opacity": 1,
          "zIndex": 1,
          "flipX": false,
          "enterEffect": "slideInLeft",
          "durationMs": 700,
          "easing": "easeOut"
        },
        {
          "id": "action-wait",
          "type": "wait",
          "durationMs": 250,
          "easing": "linear"
        },
        {
          "id": "action-parallel-focus",
          "type": "parallel",
          "durationMs": 500,
          "easing": "easeInOut",
          "actions": [
            {
              "id": "action-move-lincheng",
              "type": "moveCharacter",
              "characterId": "lincheng",
              "position": "center",
              "scale": 1.05,
              "opacity": 1,
              "zIndex": 2,
              "flipX": false,
              "durationMs": 500,
              "easing": "easeInOut"
            },
            {
              "id": "action-camera-focus",
              "type": "camera",
              "zoom": 1.03,
              "offsetX": 0,
              "offsetY": 0,
              "shake": false,
              "shakeIntensity": 0,
              "durationMs": 500,
              "easing": "easeOut"
            }
          ]
        },
        {
          "id": "action-change-smile",
          "type": "changeExpression",
          "characterId": "lincheng",
          "expression": "smile",
          "durationMs": 200,
          "easing": "linear"
        },
        {
          "id": "action-play-voice",
          "type": "playAudio",
          "channel": "voice",
          "assetId": "voice-lincheng-001",
          "loop": false,
          "durationMs": 0,
          "easing": "linear"
        }
      ]
    },
    {
      "id": "narration-intro",
      "type": "narration",
      "text": "这是一个用于验证视觉小说运行时的测试故事。",
      "textSpeed": 36,
      "waitForClick": true
    },
    {
      "id": "show-lincheng-smile",
      "type": "showCharacter",
      "characterId": "lincheng",
      "assetId": "lincheng-smile",
      "expression": "smile",
      "position": "center",
      "enterEffect": "fadeIn",
      "transitionDurationMs": 400,
      "scale": 1.05,
      "opacity": 1,
      "zIndex": 2,
      "flipX": false
    },
    {
      "id": "play-voice",
      "type": "playAudio",
      "channel": "voice",
      "assetId": "voice-lincheng-001"
    },
    {
      "id": "dialogue-greeting",
      "type": "dialogue",
      "characterId": "lincheng",
      "text": "你终于来了。我有些话想对你说。",
      "textSpeed": 42,
      "waitForClick": true
    },
    {
      "id": "camera-soft-zoom",
      "type": "camera",
      "zoom": 1.04,
      "offsetX": 0,
      "offsetY": 0,
      "shake": false,
      "shakeIntensity": 0,
      "durationMs": 400
    },
    {
      "id": "stop-voice",
      "type": "stopAudio",
      "channel": "voice"
    },
    {
      "id": "choice-stay-or-leave",
      "type": "choice",
      "prompt": "你要怎么做？",
      "options": [
        {
          "id": "stay",
          "text": "留下来听她说",
          "setVariables": {
            "stayed": true
          },
          "target": {
            "scriptId": "start",
            "label": "after_choice"
          }
        },
        {
          "id": "leave",
          "text": "转身离开",
          "setVariables": {
            "stayed": false
          },
          "target": {
            "scriptId": "start",
            "label": "after_choice"
          }
        }
      ]
    },
    {
      "id": "label-after-choice",
      "type": "label",
      "name": "after_choice",
      "description": "玩家做出是否留下的选择后进入逻辑判断。"
    },
    {
      "id": "condition-stay",
      "type": "condition",
      "condition": {
        "kind": "variable",
        "variableName": "stayed",
        "operator": "eq",
        "value": true
      },
      "trueTarget": {
        "scriptId": "start",
        "label": "stay_route"
      },
      "falseTarget": {
        "scriptId": "start",
        "label": "leave_route"
      }
    },
    {
      "id": "label-stay-route",
      "type": "label",
      "name": "stay_route",
      "description": "留下路线。"
    },
    {
      "id": "set-affection-add",
      "type": "setVariable",
      "variableName": "affection",
      "operator": "add",
      "value": 2
    },
    {
      "id": "set-ending-hint-warm",
      "type": "setVariable",
      "variableName": "endingHint",
      "operator": "set",
      "value": "warm"
    },
    {
      "id": "condition-affection",
      "type": "condition",
      "condition": {
        "kind": "and",
        "conditions": [
          {
            "kind": "variable",
            "variableName": "affection",
            "operator": "gte",
            "value": 2
          },
          {
            "kind": "variable",
            "variableName": "stayed",
            "operator": "eq",
            "value": true
          }
        ]
      },
      "trueTarget": {
        "scriptId": "start",
        "label": "ending_a"
      },
      "falseTarget": {
        "scriptId": "start",
        "label": "leave_route"
      }
    },
    {
      "id": "label-ending-a",
      "type": "label",
      "name": "ending_a",
      "description": "温柔结局标签。"
    },
    {
      "id": "ending-a",
      "type": "narration",
      "text": "你留下来听她说完，窗外的阳光也变得温柔。"
    },
    {
      "id": "hide-lincheng-a",
      "type": "hideCharacter",
      "characterId": "lincheng",
      "exitEffect": "fadeOut",
      "transitionDurationMs": 500
    },
    {
      "id": "stop-bgm-a",
      "type": "stopAudio",
      "channel": "bgm"
    },
    {
      "id": "jump-final-a",
      "type": "jump",
      "target": {
        "scriptId": "start",
        "label": "final_end"
      }
    },
    {
      "id": "label-leave-route",
      "type": "label",
      "name": "leave_route",
      "description": "离开路线。"
    },
    {
      "id": "set-ending-hint-quiet",
      "type": "setVariable",
      "variableName": "endingHint",
      "operator": "set",
      "value": "quiet"
    },
    {
      "id": "scene-corridor",
      "type": "scene",
      "backgroundAssetId": "bg-corridor",
      "transition": "slideLeft",
      "transitionDurationMs": 500
    },
    {
      "id": "play-door-sound",
      "type": "playAudio",
      "channel": "sound",
      "assetId": "sound-door"
    },
    {
      "id": "camera-corridor-shake",
      "type": "camera",
      "zoom": 1,
      "offsetX": 0,
      "offsetY": 0,
      "shake": true,
      "shakeIntensity": 8,
      "durationMs": 300
    },
    {
      "id": "ending-b",
      "type": "narration",
      "text": "你安静地离开教室，走廊里只剩下逐渐远去的脚步声。"
    },
    {
      "id": "hide-lincheng-b",
      "type": "hideCharacter",
      "characterId": "lincheng",
      "exitEffect": "slideOutRight",
      "transitionDurationMs": 500
    },
    {
      "id": "stop-bgm-b",
      "type": "stopAudio",
      "channel": "bgm"
    },
    {
      "id": "label-final-end",
      "type": "label",
      "name": "final_end",
      "description": "公共结束标签。"
    },
    {
      "id": "final-end",
      "type": "narration",
      "text": "测试故事到这里结束。"
    }
  ]
}
