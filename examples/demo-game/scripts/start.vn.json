{
  "id": "start",
  "name": "开场",
  "nodes": [
    {
      "id": "scene-classroom",
      "type": "scene",
      "backgroundAssetId": "bg-classroom",
      "transition": "fade",
      "transitionDurationMs": 600
    },
    {
      "id": "play-bgm",
      "type": "playAudio",
      "channel": "bgm",
      "assetId": "bgm-main-theme",
      "loop": true
    },
    {
      "id": "show-lincheng",
      "type": "showCharacter",
      "characterId": "lincheng",
      "assetId": "lincheng-normal",
      "expression": "normal",
      "position": "left",
      "enterEffect": "slideInLeft",
      "transitionDurationMs": 500,
      "scale": 1,
      "opacity": 1,
      "zIndex": 1,
      "flipX": false
    },
    {
      "id": "narration-intro",
      "type": "narration",
      "text": "这是一个用于验证视觉小说运行时的测试故事。",
      "textSpeed": 36,
      "waitForClick": true
    },
    {
      "id": "show-lincheng-smile",
      "type": "showCharacter",
      "characterId": "lincheng",
      "assetId": "lincheng-smile",
      "expression": "smile",
      "position": "center",
      "enterEffect": "fadeIn",
      "transitionDurationMs": 400,
      "scale": 1.05,
      "opacity": 1,
      "zIndex": 2,
      "flipX": false
    },
    {
      "id": "play-voice",
      "type": "playAudio",
      "channel": "voice",
      "assetId": "voice-lincheng-001"
    },
    {
      "id": "dialogue-greeting",
      "type": "dialogue",
      "characterId": "lincheng",
      "text": "你终于来了。我有些话想对你说。",
      "textSpeed": 42,
      "waitForClick": true
    },
    {
      "id": "camera-soft-zoom",
      "type": "camera",
      "zoom": 1.04,
      "offsetX": 0,
      "offsetY": 0,
      "shake": false,
      "shakeIntensity": 0,
      "durationMs": 400
    },
    {
      "id": "stop-voice",
      "type": "stopAudio",
      "channel": "voice"
    },
    {
      "id": "choice-stay-or-leave",
      "type": "choice",
      "prompt": "你要怎么做？",
      "options": [
        {
          "id": "stay",
          "text": "留下来听她说",
          "setVariables": {
            "stay": true
          },
          "target": {
            "scriptId": "start",
            "nodeId": "condition-stay"
          }
        },
        {
          "id": "leave",
          "text": "转身离开",
          "setVariables": {
            "stay": false
          },
          "target": {
            "scriptId": "start",
            "nodeId": "condition-stay"
          }
        }
      ]
    },
    {
      "id": "condition-stay",
      "type": "condition",
      "branches": [
        {
          "id": "branch-stay",
          "variable": "stay",
          "operator": "equals",
          "value": true,
          "target": {
            "scriptId": "start",
            "nodeId": "ending-a"
          }
        }
      ],
      "fallbackTarget": {
        "scriptId": "start",
        "nodeId": "scene-corridor"
      }
    },
    {
      "id": "ending-a",
      "type": "narration",
      "text": "你留下来听她说完，窗外的阳光也变得温柔。"
    },
    {
      "id": "hide-lincheng-a",
      "type": "hideCharacter",
      "characterId": "lincheng",
      "exitEffect": "fadeOut",
      "transitionDurationMs": 500
    },
    {
      "id": "stop-bgm-a",
      "type": "stopAudio",
      "channel": "bgm"
    },
    {
      "id": "jump-final-a",
      "type": "jump",
      "target": {
        "scriptId": "start",
        "nodeId": "final-end"
      }
    },
    {
      "id": "scene-corridor",
      "type": "scene",
      "backgroundAssetId": "bg-corridor",
      "transition": "slideLeft",
      "transitionDurationMs": 500
    },
    {
      "id": "play-door-sound",
      "type": "playAudio",
      "channel": "sound",
      "assetId": "sound-door"
    },
    {
      "id": "camera-corridor-shake",
      "type": "camera",
      "zoom": 1,
      "offsetX": 0,
      "offsetY": 0,
      "shake": true,
      "shakeIntensity": 8,
      "durationMs": 300
    },
    {
      "id": "ending-b",
      "type": "narration",
      "text": "你安静地离开教室，走廊里只剩下逐渐远去的脚步声。"
    },
    {
      "id": "hide-lincheng-b",
      "type": "hideCharacter",
      "characterId": "lincheng",
      "exitEffect": "slideOutRight",
      "transitionDurationMs": 500
    },
    {
      "id": "stop-bgm-b",
      "type": "stopAudio",
      "channel": "bgm"
    },
    {
      "id": "final-end",
      "type": "narration",
      "text": "测试故事到这里结束。"
    }
  ]
}
